# Copy this file to .env and fill in your token. .env is gitignored — never commit it.

# HuggingFace Inference Providers token (required).
# Get one at https://huggingface.co/settings/tokens — needs "Read" access at minimum.
# Used to call:
#   - meta-llama/Llama-3.3-70B-Instruct  (Stage 5: reason + generate)
#   - meta-llama/Llama-3.1-8B-Instruct   (Stage 3b: intent classifier)
HF_TOKEN=

# Optional overrides — defaults are baked into the code; only set these to swap models.
# STAGE5_MODEL=meta-llama/Llama-3.3-70B-Instruct
# STAGE3B_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Optional HF Inference Providers backend pin. Leave unset to let HF auto-route.
# Examples: "together", "fireworks-ai", "cerebras", "hyperbolic", "novita"
# HF_PROVIDER=
